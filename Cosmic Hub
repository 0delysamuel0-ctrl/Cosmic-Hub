-- FUNCTION CREATE TAB
function createTab(name)
	local btn = Instance.new("TextButton", sidebar)
	btn.Size = UDim2.new(1,0,0,45)
	btn.BackgroundColor3 = Color3.fromRGB(10,10,10)
	btn.Text = "   "..name
	btn.Font = Enum.Font.Gotham
	btn.TextSize = 22
	btn.TextColor3 = Color3.new(1,1,1)
	btn.TextXAlignment = Enum.TextXAlignment.Left
	
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,10)

	local stroke = Instance.new("UIStroke", btn)
	stroke.Color = Color3.fromRGB(0,80,255)

	return btn
end

-- CLEAR CONTENT
function clear()
	for _,v in pairs(content:GetChildren()) do
		if not v:IsA("UIStroke") and not v:IsA("UICorner") then
			v:Destroy()
		end
	end
end

-- CREATE BUTTON IN CONTENT
function createContentButton(text, callback, posY)
	local btn = Instance.new("TextButton", content)
	btn.Size = UDim2.new(0,650,0,50)
	btn.Position = UDim2.new(0.04,0,posY,0)
	btn.BackgroundColor3 = Color3.fromRGB(15,15,15)
	btn.Text = text
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 22
	btn.TextColor3 = Color3.new(1,1,1)

	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,10)

	local stroke = Instance.new("UIStroke", btn)
	stroke.Color = Color3.fromRGB(0,80,255)

	btn.MouseButton1Click:Connect(callback)
end

